{
  "manifest_version": 3,
  "name": "Realtime Meeting Translator",
  "version": "1.0",
  "description": "Phiên dịch realtime cho Google Meet, Zoom, Teams",
  "permissions": ["tabCapture", "activeTab", "scripting", "offscreen", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_popup": "popup/index.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["processor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
